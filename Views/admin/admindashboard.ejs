<%- include('../../Views/layout/admin/header.ejs') %>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <h1 class="mt-4">Admin Dashboard</h1>

                <!-- Order Details Module -->
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="fas fa-chart-area"></i>
                        Order Details
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-xl-3 col-md-6">
                                <div class="card bg-primary text-white mb-4">
                                    <div class="card-body">Total Orders: {{ total_orders }}</div>
                                </div>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <div class="card bg-success text-white mb-4">
                                    <div class="card-body">Total Revenue: ${{ total_revenue|round(2) }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sales Details Module -->
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="fas fa-table"></i>
                        Sales Details
                    </div>
                    <div class="card-body">
                        {% if sales_details %}
                        <div class="row">
                            <div class="col-md-6">
                                <p>Date: {{ sales_details.date.strftime('%Y-%m-%d') }}</p>
                                <p>Total Revenue: ${{ sales_details.total_revenue|round(2) }}</p>
                                <p>Total Orders: {{ sales_details.total_orders }}</p>
                            </div>
                        </div>
                        {% else %}
                        <p>No sales data available</p>
                        {% endif %}
                    </div>
                </div>

                <!-- Recent Orders Module -->
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-table"></i>
                        Recent Orders
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer Name</th>
                                    <th>Total Amount</th>
                                    <th>Order Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in recent_orders %}
                                <tr>
                                    <td>{{ order.id }}</td>
                                    <td>{{ order.customer_name }}</td>
                                    <td>${{ order.total_amount|round(2) }}</td>
                                    <td>{{ order.order_date.strftime('%Y-%m-%d %H:%M') }}</td>
                                    <td>{{ order.status }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../../Views/layout/admin/footer.ejs') %>s